# Discord Application ID from Discord Developer Portal (required)
VITE_DISCORD_CLIENT_ID=

# Backend API URL — your deployed backend domain
# Netlify example: https://watchtogether-backend.fly.dev
# Local dev: http://localhost:3001
# When backend serves frontend (Docker), leave empty to use same origin
VITE_API_URL=http://localhost:3001

# Apinator public key (from Apinator console, safe to expose)
VITE_APINATOR_KEY=
VITE_APINATOR_CLUSTER=eu
